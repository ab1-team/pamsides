  faUsers,
  faHome,
  faBuilding,
  faArchive,
  faDollarSign,
  faTint,
  faPlus,
  faSearch,
  faBell,
  faQuestionCircle,
  faUser,
  faSignOutAlt,
  faTimes,
  faLock,
  faEyeSlash,
  faSpinner,
  faArrowRight,
