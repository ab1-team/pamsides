# Set default behavior to handle line endings automatically
* text=auto

# Explicitly set line endings to LF for code and text files
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Denote binary files to prevent Git from attempting to modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
